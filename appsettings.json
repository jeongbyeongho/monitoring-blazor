      "RecoveryCooldownMinutes": 10,
      "AnomalyEnabled": false,
      "AnomalyWindow": 20,
      "AnomalyStdDev": 2.0,
      "AnomalyMinDelta": 10,
      "AnomalyCooldownMinutes": 15,
      "Overrides": {
        "HOST-01": {
          "CpuThreshold": 85,
          "RamThreshold": 92,
          "DiskThreshold": 97
        }
      }
    },
    "Dooray": {
      "Enabled": false,
      "ChannelId": "",
      "ApiToken": ""
    }
  },
  "AllowedHosts": "*"
}
